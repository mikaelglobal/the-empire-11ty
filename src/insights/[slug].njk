---
layout: layout.njk
pagination:
  data: collections.insights
  size: 1
  alias: insight
permalink: "insights/{{ insight.data.slug }}/index.html"
---
<main class="insights-single">
  <article class="insight-article">
    <!-- Back link -->
    <a href="/insights/" class="back-to-insights">← Back to all insights</a>

    <!-- Responsive Hero Image -->
    <picture class="insight-article-image-wrap">
      <source 
        media="(min-width: 768px)" 
        srcset="{{ insight.data.image }}" 
      />
      <source 
        media="(max-width: 767px)" 
        srcset="{{ insight.data.imageMobile }}" 
      />
      <img 
        class="insight-article-image" 
        src="{{ insight.data.image }}" 
        alt="{{ insight.data.title }}" 
        loading="eager" 
        width="1200" 
        height="600"
      />
    </picture>

    <!-- Meta -->
    <div class="insight-article-meta">
      <span class="insight-article-date">{{ insight.data.date | formatDate }}</span>
      <span class="insight-article-readtime">{{ insight.data.readTime }} min read</span>
    </div>

    <!-- Tags -->
    <div class="insight-article-tags">
      {% for tag in insight.data.tags %}
      <span class="insight-article-tag">{{ tag }}</span>
      {% endfor %}
    </div>

    <!-- Title -->
    <h1 class="insight-article-title">{{ insight.data.title }}</h1>

    <!-- Content -->
    <div class="insight-article-content">
      {{ insight.data.content | safe }}
    </div>

    <!-- Footer / Share -->
    <div class="insight-article-footer">
      <p class="insight-article-share">
        Liked this? <a href="mailto:{{ site.social.email }}">Let's talk</a> about your next project.
      </p>
    </div>
  </article>
</main>