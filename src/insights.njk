---
layout: layout.njk
title: Insights — MIKAEL GLOBAL
description: Articles and thoughts on data analysis, web development, and business intelligence from MIKAEL GLOBAL.
pageClass: page-insights
permalink: /insights/index.html
---

<main class="insights-page">
  <!-- Hero -->
  <section class="insights-hero">
    <div class="section-eyebrow">Insights</div>
    <h1 class="section-title">Ideas & Perspectives.</h1>
    <p class="about-bio">
      Deep dives, frameworks, and lessons learned from our work in data analysis,
      web development, and business intelligence.
    </p>
  </section>

  <!-- Insights Grid -->
  <section class="insights-grid-section">
    <div class="insights-grid">
      {% for insight in collections.insights %}
      <article class="insight-card" data-tags="{{ insight.data.tags | join(',') }}">
        <!-- Responsive Picture -->
        <picture class="insight-card-image-wrap">
          <source 
            media="(min-width: 768px)" 
            srcset="{{ insight.data.image }}" 
          />
          <source 
            media="(max-width: 767px)" 
            srcset="{{ insight.data.imageMobile }}" 
          />
          <img 
            class="insight-card-image" 
            src="{{ insight.data.image }}" 
            alt="{{ insight.data.title }}" 
            loading="lazy" 
            width="600" 
            height="300"
          />
        </picture>
        <div class="insight-card-meta">
          <span class="insight-card-date">{{ insight.data.date | formatDate }}</span>
          <span class="insight-card-readtime">{{ insight.data.readTime }} min read</span>
        </div>
        <div class="insight-card-tags">
          {% for tag in insight.data.tags %}
          <span class="insight-tag">{{ tag }}</span>
          {% endfor %}
        </div>
        <h3 class="insight-card-title">{{ insight.data.title }}</h3>
        <p class="insight-card-excerpt">{{ insight.data.excerpt }}</p>
        <a href="{{ insight.url }}" class="insight-card-link">Read the full insight →</a>
      </article>
      {% endfor %}
    </div>
  </section>
</main>