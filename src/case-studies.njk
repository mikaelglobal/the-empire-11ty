---
layout: layout.njk
title: Case Studies — MIKAEL GLOBAL
description: In-depth case studies on data analysis and web development projects from MIKAEL GLOBAL.
pageClass: page-case-studies
permalink: /case-studies/index.html
---

<main class="case-studies-page">
  <!-- Hero -->
  <section class="case-studies-hero">
    <div class="section-eyebrow">Case Studies</div>
    <h1 class="section-title">Project Deep Dives.</h1>
    <p class="about-bio">
      Detailed breakdowns of our work — the problems we solved, the tools we used,
      and the outcomes we delivered.
    </p>
  </section>

  <!-- Case Studies Grid -->
  <section class="case-studies-grid-section">
    <div class="case-studies-grid">
      {% for caseStudy in collections.caseStudies %}
      <a href="{{ caseStudy.url }}" class="case-study-card" data-tags="{{ caseStudy.data.tags | join(',') }}">
        <!-- Local Image -->
        <div class="case-study-image-wrap">
          <img 
            class="case-study-image" 
            src="{{ caseStudy.data.image }}" 
            alt="{{ caseStudy.data.title }}" 
            loading="lazy" 
            width="600" 
            height="400"
          />
        </div>
        <div class="case-study-card-content">
          <div class="case-study-card-meta">
            <span class="case-study-client">{{ caseStudy.data.client }}</span>
            <span class="case-study-year">{{ caseStudy.data.year }}</span>
          </div>
          <h3 class="case-study-card-title">{{ caseStudy.data.title }}</h3>
          <p class="case-study-card-desc">{{ caseStudy.data.description }}</p>
          <div class="case-study-card-tags">
            {% for tag in caseStudy.data.tags %}
            <span class="case-study-tag">{{ tag }}</span>
            {% endfor %}
          </div>
          <span class="case-study-card-link">Read the full case study →</span>
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
</main>